{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devflow.local/schemas/context-builder/context-build-request.schema.json",
  "title": "DevFlow Context Build Request",
  "description": "Entrada canónica del Context Builder Agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "attempt"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^TASK-(?:0*[1-9][0-9]*)$",
      "description": "Identificador de la tarea a contextualizar."
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "description": "Número de intento a preparar."
    }
  }
}
