{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./rules/general.md",
    "./rules/git-policy.md",
    "./rules/documentation-policy.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git commit *": "deny",
      "git push *": "deny"
    }
  }
}
